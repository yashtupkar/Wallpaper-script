# ─────────────────────────────────────────────
# API Keys
# ─────────────────────────────────────────────

# Unsplash API key (https://unsplash.com/developers)
UNSPLASH_KEY=

# Pexels API key (https://www.pexels.com/api/)
PEXELS_KEY=

# Wallhaven API key (optional) (https://wallhaven.cc/settings/account)
WALLHAVEN_KEY=

# ─────────────────────────────────────────────
# Wallpaper Settings
# ─────────────────────────────────────────────

# Category for wallpapers
# Options: nature, mountains, minimal, space, cyberpunk, programming, dark, abstract, architecture, anime
CATEGORY=minimal

# Wallpaper source
# Options: unsplash, pexels, wallhaven
SOURCE=unsplash

# ─────────────────────────────────────────────
# Scheduling
# ─────────────────────────────────────────────

# How often to change the wallpaper
# Options: 15m, 30m, 1h, 6h, 12h, daily
CHANGE_INTERVAL=1h

# ─────────────────────────────────────────────
# History (Duplicate Prevention)
# ─────────────────────────────────────────────

# Keep wallpaper history to prevent duplicates (recommended: true)
KEEP_HISTORY=true

# Maximum number of wallpaper IDs to remember
HISTORY_MAX_SIZE=5000
